import cv2
from ultralytics import YOLO
import os
from datetime import datetime
import time
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
from email.mime.base import MIMEBase
from email import encoders

# Email Configuration (Update these with your details)
SENDER_EMAIL = "senders_email"  # Your email
SENDER_PASSWORD = "your_email_automation_password"  # Your app password (for Gmail, use app password)
RECIPIENT_EMAIL = "recivers_email"  # Who to send alerts to
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = 587

def send_alert_email(screenshot_path):
    """Send email alert with screenshot when helmet not detected"""
    try:
        message = MIMEMultipart()
        message["From"] = SENDER_EMAIL
        message["To"] = RECIPIENT_EMAIL
        message["Subject"] = "⚠️ Safety Alert: Helmet Not Detected"
        
        body = """
Dear User,

We detected that you are not wearing a helmet!

🚨 SAFETY ALERT 🚨
Please wear your helmet next time for your safety. Helmets save lives!

Your detection was recorded on: {}

Screenshot of the incident is attached below.

Stay safe!
        """.format(datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
        
        message.attach(MIMEText(body, "plain"))
        
        # Attach screenshot
        if os.path.exists(screenshot_path):
            with open(screenshot_path, "rb") as attachment:
                part = MIMEBase("application", "octet-stream")
                part.set_payload(attachment.read())
            encoders.encode_base64(part)
            part.add_header("Content-Disposition", f"attachment; filename= {os.path.basename(screenshot_path)}")
            message.attach(part)
        
        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT)
        server.starttls()
        server.login(SENDER_EMAIL, SENDER_PASSWORD)
        server.send_message(message)
        server.quit()
        
        print("✉️ Alert email with screenshot sent successfully!")
    except Exception as e:
        print(f"Error sending email: {e}")

model = YOLO("model/best.pt")
#model.to('cuda')  # Move model to GPU

# Create directory for screenshots if it doesn't exist
screenshot_dir = "screenshots"
if not os.path.exists(screenshot_dir):
    os.makedirs(screenshot_dir)

cap = cv2.VideoCapture(0)

print("Starting real-time helmet detection...")
print("Press 'q' key to stop detection\n")

last_detection_time = 0  # Track last detection time for cooldown
frame_count = 0

while True:
    ret, frame = cap.read()

    if not ret:
        break

    results = model(frame)
    
    frame_count += 1
    
    # Check for detections without helmet
    no_helmet_detected = False
    for box in results[0].boxes:
        cls = int(box.cls[0])
        conf = float(box.conf[0])
        
        # Adjust class number based on your model's classes
        # Usually: 0 = helmet, 1 = no helmet
        if cls == 1:  # No helmet detected
            no_helmet_detected = True
            current_time = time.time()
            # Check if 3 seconds have passed since last detection
            if current_time - last_detection_time >= 3:
                timestamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")[:-3]
                filename = os.path.join(screenshot_dir, f"no_helmet_{timestamp}.jpg")
                cv2.imwrite(filename, frame)
                print(f"[ALERT] No helmet detected! Screenshot saved: {filename}")
                print("Sending alert email with screenshot...")
                send_alert_email(filename)
                last_detection_time = current_time  # Update last detection time
    
    # Show real-time detection status
    if frame_count % 30 == 0:  # Print every 30 frames
        status = "🔴 NO HELMET" if no_helmet_detected else "🟢 Helmet OK"
        print(f"Frame {frame_count}: {status}")

    annotated_frame = results[0].plot()
    
    # Display frame in real-time (non-blocking)
    try:
        cv2.imshow("Real-Time Helmet Detection", annotated_frame)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
    except Exception as e:
        print(f"GUI not available: {e}")
        if frame_count % 100 == 0:
            print(f"✓ Detection running... Frame {frame_count}")

cap.release()
try:
    cv2.destroyAllWindows()
except:
    pass
print("\nDetection stopped.")